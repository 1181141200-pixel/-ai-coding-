/* 全局主题：白绿极简，时尚而不夸张 */
page { background-color: #f6f8f7; }
.container { padding: 20rpx; }
.title, .header { font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; color: #2a2a2a; }
.item { padding: 16rpx 0; border-bottom: 1rpx solid #e9eded; }
.link { color: #19a15e; }

/* 卡片与文本 */
.card { padding: 18rpx; border: 1rpx solid #e6ece8; border-radius: 10rpx; background: #ffffff; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.02); }
.line { font-size: 26rpx; color: #2a2a2a; margin-bottom: 8rpx; }
.empty { text-align: center; color: #7a7a7a; padding: 40rpx 0; }
.hint { color: #7a7a7a; font-size: 24rpx; }
.perm-hint { margin-top: 8rpx; font-size: 22rpx; color: #7a7a7a; }

/* 按钮：统一主色与尺寸（更适合老人） */
button { min-height: 64rpx; border-radius: 10rpx; }
button[type=primary] { background-color: #19a15e; color: #fff; border: 1rpx solid #169456; }
button[type=warn] { background-color: #e54d42; color: #fff; border: 1rpx solid #d13f35; }
button[disabled] { opacity: 0.6; }
.plain-btn { border: 1rpx solid #cfd7d2; background: #f7faf8; color: #2a2a2a; }
.actions { margin-top: 16rpx; display: flex; gap: 16rpx; }

/* -------------------- 排版工具 -------------------- */
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 26rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.subtitle { color: #444444; font-weight: 500; }
.muted { color: #7a7a7a; }
.strong { font-weight: 600; }

/* -------------------- 间距工具 -------------------- */
.mt8 { margin-top: 8rpx; }
.mt12 { margin-top: 12rpx; }
.mt16 { margin-top: 16rpx; }
.mt24 { margin-top: 24rpx; }
.mb8 { margin-bottom: 8rpx; }
.mb12 { margin-bottom: 12rpx; }
.mb16 { margin-bottom: 16rpx; }
.mb24 { margin-bottom: 24rpx; }
.pt8 { padding-top: 8rpx; }
.pt12 { padding-top: 12rpx; }
.pt16 { padding-top: 16rpx; }
.pb8 { padding-bottom: 8rpx; }
.pb12 { padding-bottom: 12rpx; }
.pb16 { padding-bottom: 16rpx; }
.px16 { padding-left: 16rpx; padding-right: 16rpx; }
.py16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* -------------------- 色彩工具 -------------------- */
.text-primary { color: #19a15e; }
.text-secondary { color: #4a4a4a; }
.text-accent { color: #1c7cd6; }
.text-danger { color: #e54d42; }
.text-warning { color: #f0b429; }

.bg-primary-soft { background-color: #eef7f2; color: #1e794b; border: 1rpx solid #d7e8de; }
.bg-accent-soft { background-color: #eef4fb; color: #1c62ab; border: 1rpx solid #d7e4f3; }
.bg-danger-soft { background-color: #fdeeee; color: #b5332a; border: 1rpx solid #f6d4d1; }
.bg-warning-soft { background-color: #fff7e8; color: #b38219; border: 1rpx solid #f4e4bf; }
.bg-gray-soft { background-color: #f7f9f8; color: #5a5a5a; border: 1rpx solid #e6ece8; }

/* -------------------- 分隔与阴影 -------------------- */
.divider { height: 1rpx; background-color: #e9eded; margin: 16rpx 0; }
.shadow-sm { box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.02); }
.shadow-md { box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }

/* -------------------- 区块容器 -------------------- */
.section { background: #ffffff; border: 1rpx solid #e6ece8; border-radius: 10rpx; padding: 16rpx; }

/* -------------------- 列表与条目 -------------------- */
.list { padding: 0; }
.list-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 16rpx; border-bottom: 1rpx solid #e9eded; }
.list-item:last-child { border-bottom: none; }
.list-item-title { color: #2a2a2a; font-size: 28rpx; }
.list-item-subtitle { color: #7a7a7a; font-size: 24rpx; margin-top: 4rpx; }
.chevron { color: #b7b7b7; font-size: 28rpx; }

/* -------------------- 顶部返回箭头 -------------------- */
.back-bar { display: flex; align-items: center; height: 48rpx; margin-bottom: 8rpx; }
.back-arrow { width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center; font-size: 36rpx; color: #19a15e; border: 1rpx solid #d7e8de; border-radius: 999rpx; background: #eef7f2; }
.back-arrow:active { background: #e6f3ec; }

/* -------------------- 首页滚屏（英雄区） -------------------- */
.hero-swiper { height: 240rpx; border-radius: 12rpx; overflow: hidden; margin-bottom: 16rpx; }
.hero-slide { display: flex; align-items: center; justify-content: center; height: 100%; }
.hero-1 { background: linear-gradient(135deg, #e8f6ef, #ffffff); color: #1e794b; }
.hero-2 { background: linear-gradient(135deg, #eef4fb, #ffffff); color: #1c62ab; }
.hero-3 { background: linear-gradient(135deg, #fff7e8, #ffffff); color: #b38219; }
.hero-title { font-size: 32rpx; font-weight: 600; }

/* 错误态与提示（提升可读性） */
.error-block { padding: 18rpx; border: 1rpx dashed #efc7c7; border-radius: 12rpx; background: #fff6f6; margin: 18rpx 0; }
.error-title { font-size: 30rpx; color: #a12222; margin-bottom: 10rpx; }
.error-msg { font-size: 28rpx; color: #a33; margin-bottom: 14rpx; }
.error-actions { display: flex; gap: 16rpx; }

/* 登录动作区 */
.login-actions { display: flex; gap: 14rpx; }

/* 标签（状态/提示），白绿为主，避免单调 */
.tag { font-size: 24rpx; padding: 6rpx 10rpx; border-radius: 8rpx; border: 1rpx solid transparent; display: inline-flex; align-items: center; }
.tag-green { color: #1f7f52; background: #eaf6ef; border-color: #cfe7d8; }
.tag-gray { color: #595959; background: #f6f7f8; border-color: #e0e3e6; }
.tag-blue { color: #106ba3; background: #e6f2fb; border-color: #cbe4f7; }
.tag-red { color: #a12b2b; background: #fdecec; border-color: #f5cdcd; }
.tag-yellow { color: #8a5d00; background: #fff6d8; border-color: #f1e3b2; }

/* 输入与选择统一样式（提升对比度与焦点可见性） */
.input { border: 1rpx solid #cfd7d2; border-radius: 10rpx; padding: 12rpx 14rpx; background: #fff; color: #2a2a2a; }
.input:focus { border-color: #19a15e; box-shadow: 0 0 0 4rpx rgba(25,161,94,0.12); }
.picker { border: 1rpx solid #e0e6e2; border-radius: 10rpx; background: #f7faf8; }
.picker-inner { padding: 12rpx 16rpx; font-size: 26rpx; color: #2a2a2a; }

/* 辅助：大字号模式（可在根容器加 .a11y-large 开启） */
.a11y-large .title, .a11y-large .header { font-size: 38rpx; }
.a11y-large .line { font-size: 32rpx; }
.a11y-large button { min-height: 80rpx; }
.a11y-large .hint, .a11y-large .perm-hint { font-size: 28rpx; }

/* 轻反馈：按钮按压态 */
button[type=primary]:active { background-color: #169456; }
button[type=warn]:active { background-color: #d13f35; }