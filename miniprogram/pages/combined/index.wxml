<view class="page">
  <view class="segmented">
    <view class="seg-item {{activeTab==='lines'?'active':''}}" bindtap="switchTab" data-tab="lines">线路</view>
    <view class="seg-item {{activeTab==='activities'?'active':''}}" bindtap="switchTab" data-tab="activities">活动</view>
    <view class="seg-item {{activeTab==='bases'?'active':''}}" bindtap="switchTab" data-tab="bases">基地</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中…</view>
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <!-- 列表：复用全局 list 样式 -->
  <view class="list" wx:if="{{!loading && !error}}">
    <!-- 线路 -->
    <block wx:if="{{activeTab==='lines'}}">
      <block wx:for="{{lines}}" wx:key="id">
        <navigator class="list-item" url="/pages/lines/detail?id={{item.id}}">
          <view class="list-item-title">{{item.name || item.title || '未命名线路'}}</view>
          <view class="chevron">›</view>
        </navigator>
      </block>
      <view wx:if="{{!lines || lines.length===0}}" class="empty">暂无线路</view>
    </block>

    <!-- 活动 -->
    <block wx:if="{{activeTab==='activities'}}">
      <block wx:for="{{activities}}" wx:key="id">
        <navigator class="list-item" url="/pages/activities/detail?id={{item.id}}">
          <view class="list-item-title">{{item.name || item.title || '未命名活动'}}</view>
          <view class="chevron">›</view>
        </navigator>
      </block>
      <view wx:if="{{!activities || activities.length===0}}" class="empty">暂无活动</view>
    </block>

    <!-- 基地 -->
    <block wx:if="{{activeTab==='bases'}}">
      <block wx:for="{{bases}}" wx:key="id">
        <navigator class="list-item" url="/pages/bases/detail?id={{item.id}}">
          <view class="list-item-title">{{item.name || item.title || '未命名基地'}}</view>
          <view class="chevron">›</view>
        </navigator>
      </block>
      <view wx:if="{{!bases || bases.length===0}}" class="empty">暂无基地</view>
    </block>
  </view>
</view>