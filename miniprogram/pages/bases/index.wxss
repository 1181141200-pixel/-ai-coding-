.item{padding:8px 0;border-bottom:1px solid #eee;}
.card{margin:12px 0;padding:12px;border:1px solid #eee;border-radius:6px;background:#fff;}
.line{margin-bottom:6px;color:#333;}
.login-row{display:flex;gap:8px;align-items:center;}
.phone-input{flex:1;height:32px;border:1px solid #ddd;border-radius:4px;padding:0 8px;}
.hint{margin-top:6px;color:#999;font-size:12px;}
.empty{padding:16px;color:#666;text-align:center;}
/* 错误态样式 */
.error-block{margin:12px 0;padding:12px;border:1px dashed #f0bfbf;background:#fff6f6;border-radius:6px;}
.error-title{font-size:14px;color:#b00000;margin-bottom:4px;}
.error-msg{font-size:13px;color:#a33;margin-bottom:8px;}
.error-actions{display:flex;gap:8px;}